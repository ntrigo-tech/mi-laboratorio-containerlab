{
    "name": "Containerlab Workspace",
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "settings": {},
    "extensions": [
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml"
    ],
    "runArgs": [
        "--privileged",
        "--pid=host"
    ],
    "postCreateCommand": "curl -sL https://get.containerlab.dev | sudo bash"
}
